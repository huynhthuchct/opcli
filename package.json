{
  "name": "@huynhthuc/opcli",
  "version": "0.1.1",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "opcli": "./bin/opcli.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "openproject",
    "cli",
    "task-management",
    "time-tracking"
  ],
  "author": "thuchuynh",
  "license": "ISC",
  "description": "CLI tool for OpenProject task management",
  "repository": {
    "type": "git",
    "url": "https://github.com/huynhthuchct/opcli"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "node-html-markdown": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
